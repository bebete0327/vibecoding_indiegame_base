# Godot 4+ specific ignores
.godot/
/android/
*.translation
*.pot
export_presets.cfg
export_presets.cfg.backup

# Knowledge Base raw files (personal/unprocessed) — 폴더는 유지, 내용만 무시
knowledge_base/Raw/*
!knowledge_base/Raw/.gitkeep

# Claude Code
.claude/plans/
.claude/sessions/
.claude/settings.local.json
.claude/shell-snapshots/
.claude/backups/

# OS
.DS_Store
Thumbs.db
desktop.ini

# 런타임 쓰기 디렉토리 (ProjectPaths.writable_dir) — 에디터 실행 시 프로젝트 루트에 생성
# 새 subdir 추가 시 여기도 등록할 것
screenshots/
saves/
logs/
profiles/

# graphify — 전이트 파일만 무시, 그래프 산출물(graph.html/GRAPH_REPORT.md/graph.json) 은 커밋
graphify-out/.graphify_*
graphify-out/cost.json
graphify-out/.needs_update

# Spine GDExtension 런타임 (Esoteric Software 라이선스 보호 + 43MB 바이너리)
# 설치: scripts/dev_tools/install_spine_runtime.sh (공식 S3 에서 자동 다운로드)
/bin/
